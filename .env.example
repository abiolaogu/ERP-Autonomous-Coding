# Database
DATABASE_URL=${ERP_SHARED_DB_URL:-postgres://erp_admin:changeme_in_production@localhost:5432/erp_shared?sslmode=disable}
DB_HOST=localhost
DB_PORT=5432
DB_USER=erp
DB_PASSWORD=erp
DB_NAME=erp_coding
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=80
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_IDLE=5m
DB_CONN_MAX_LIFETIME=30m

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=8090
MODULE_NAME=ERP-Autonomous-Coding
LOG_LEVEL=info
CACHE_TTL=45s

# Auth (IAM Integration)
IAM_URL=http://localhost:8081
JWT_SECRET=change-me-in-production

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
